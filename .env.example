DEBUG=True
SECRET_KEY=django-insecure-restoapp-secret-key-change-in-production-xyz123

# PostgreSQL
DATABASE_URL=postgres://restouser:restopassword@db:5432/restoapp

POSTGRES_DB=restoapp
POSTGRES_USER=restouser
POSTGRES_PASSWORD=restopassword

# PGADMIN
PGADMIN_DEFAULT_EMAIL=admin@pgadmin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# MongoDB
MONGO_URI=mongodb://root:admin@mongo:27017/
MONGO_DB_NAME=restoapp
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=admin

#MOGO EXPRESS
# ME_CONFIG_MONGODB_ADMINUSERNAME=root
# ME_CONFIG_MONGODB_ADMINPASSWORD=admin
# ME_CONFIG_MONGODB_SERVER=mongo
ME_CONFIG_BASICAUTH_ENABLED=true
ME_CONFIG_MONGODB_URL=mongodb://root:admin@mongo:27017/

ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin
ME_PORT=8081

# Redis
REDIS_URL=redis://redis:6379/0

ALLOWED_HOSTS=*